name: GadgetPulse auto-publish

on:
  schedule:
    - cron: '0 7 * * *'   # 07:00 UTC daily
    - cron: '0 15 * * *'  # 15:00 UTC daily
  workflow_dispatch:
    inputs:
      count:
        description: 'How many articles to publish'
        default: '3'

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - run: npm install sharp
      - name: Generate articles
        env:
          LLM_API_KEY: ${{ secrets.LLM_API_KEY }}
          LLM_API_URL: ${{ secrets.LLM_API_URL }}
          LLM_MODEL: ${{ secrets.LLM_MODEL }}
          DOMAIN: https://gadgetpulse.pages.dev
        run: node run.mjs --count=${{ github.event.inputs.count || '3' }}
      - name: Build with ads
        env:
          DOMAIN: https://gadgetpulse.pages.dev
          AD: ${{ secrets.AD }}
          AD_SIDEBAR: ${{ secrets.AD_SIDEBAR }}
          SOCIAL_BAR: ${{ secrets.SOCIAL_BAR }}
          HEAD_EXTRA: ${{ secrets.HEAD_EXTRA }}
        run: node generate.mjs
      - name: Commit new articles
        run: |
          git config user.name 'gadgetpulse-bot'
          git config user.email 'bot@gadgetpulse'
          git add data/articles.json img || true
          git commit -m "auto: new articles $(date -u +%F)" || echo "nothing to commit"
          git push || true
      - name: Deploy to Cloudflare Pages
        env:
          CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
        run: npx wrangler pages deploy dist --project-name=gadgetpulse
